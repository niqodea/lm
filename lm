#!/usr/bin/env python3
"""CLI tool for interacting with Claude from the terminal."""

import argparse
import datetime
import io
import json
import os
import subprocess
import sys
import time
from pathlib import Path

CONFIG_PATH = Path.home() / ".config" / "lm"
PROMPTS_PATH = CONFIG_PATH / "prompts"
THREADS_PATH = CONFIG_PATH / "threads"
EMPTY_CWD_PATH = CONFIG_PATH / ".empty-cwd"

QUERY_EDITMSG_PATHNAME = ".QUERY_EDITMSG.md"
SESSION_PATHNAME = ".session"

CONTEXT_SECTION_HEADER = "lm Context"
SCISSORS_LINE = "<!-- ------------------------ >8 ------------------------ -->"

SYSTEM_PROMPT = f"""
You are a helpful assistant. Answer the question concisely. \
Contextual information is provided after in the `{CONTEXT_SECTION_HEADER}` section.
"""

QUERY_SUMMARY_MAX_LENGTH = 100

# TODO: should we avoid hardcoding this? works fine for current latencies, but might be
# annoying if streaming becomes faster in the future. Perhaps configurable, perhaps
# automatically adapt?
CHAR_DELAY = 1 / 1000

# TODO: Provide something to initialize config directory once
# TODO: Implement forking with symlinks to share common history between threads
# Seems like we will need to fork at each turn to edit previous messages
# TODO: Allow to specify Claude model
# TODO: Inspect claude command flags for further improvements
# TODO: Address annoying UX of text moving upwards as the answer is being streamed
# TODO: Implement top-to-bottom message strategy, but only with recognized editors that
# can place the cursor at the bottom


def main() -> None:
    """Entry point for the lm CLI."""
    parser = argparse.ArgumentParser(prog="lm")
    parser.add_argument(
        "--preset",
        help="prompt name (maps to ~/.config/lm/presets/<name>.md)",
        type=str,
    )
    # TODO: Should we differentiate thread creation vs continuation?
    parser.add_argument(
        "--thread",
        help="thread name (maps to ~/.config/lm/threads/<name>)",
        type=str,
    )
    args = parser.parse_args()
    preset: str | None = args.preset

    if args.thread is not None:
        thread_name: str = args.thread
    else:
        thread_name = datetime.datetime.now().astimezone().strftime("%Y%m%d-%H%M%S")

    thread_path = THREADS_PATH / thread_name
    thread_path.mkdir(exist_ok=True)

    query_editmsg_buf = io.StringIO()

    if preset is not None:
        preset_path = PROMPTS_PATH / f"{preset}.md"
        if not preset_path.exists():
            sys.exit(f"Preset not found: {preset_path}")
        initial_prompt = preset_path.read_text()
        query_editmsg_buf.write(initial_prompt)

    if not sys.stdin.isatty():
        context = sys.stdin.read()
        query_editmsg_buf.write(f"\n\n# {CONTEXT_SECTION_HEADER}\n\n{context}")

    next_idx = _get_next_idx(thread_path)
    if next_idx > 0:
        query_editmsg_buf.write(f"\n\n{SCISSORS_LINE}")
        for idx in range(next_idx - 1, -1, -1):
            past_answer_path = thread_path / _get_answer_pathname(idx)
            past_query_path = thread_path / _get_query_pathname(idx)
            query_editmsg_buf.write(
                f"\n\n<!-- lm Answer {idx} -->\n\n{past_answer_path.read_text()}"
            )
            query_editmsg_buf.write(
                f"\n\n<!-- lm Query {idx} -->\n\n{past_query_path.read_text()}"
            )

    query_editmsg_path = thread_path / QUERY_EDITMSG_PATHNAME
    query_editmsg_path.write_text(query_editmsg_buf.getvalue())
    editor = os.environ.get("EDITOR", "vim")
    with Path("/dev/tty").open() as tty:
        subprocess.run(  # noqa: S603  (running the user editor expected to be safe)
            [editor, str(query_editmsg_path)],
            stdin=tty,
            stdout=sys.stdout,
            stderr=sys.stderr,
            check=True,
        )
    query = query_editmsg_path.read_text().split(f"\n{SCISSORS_LINE}\n")[0].strip()
    query_editmsg_path.unlink()

    if len(query) == 0:
        sys.exit("Query is empty, exiting.")

    query_path = thread_path / _get_query_pathname(next_idx)
    query_path.write_text(query)

    session_path = thread_path / SESSION_PATHNAME
    if session_path.exists():
        session_id: str | None = session_path.read_text()
    else:
        session_id = None

    query_summary = query
    query_summary = " ".join(query_summary.split())  # collapse all separators to spaces
    if len(query_summary) > QUERY_SUMMARY_MAX_LENGTH:
        query_summary_start = query_summary[: QUERY_SUMMARY_MAX_LENGTH // 2 - 1]
        query_summary_end = query_summary[-QUERY_SUMMARY_MAX_LENGTH // 2 + 2 :]
        query_summary = f"{query_summary_start}...{query_summary_end}"

    sys.stdout.write(f"Query: {query_summary}\n")
    sys.stdout.write("Waiting for lm answer...")
    sys.stdout.flush()

    inference_session_id, answer = _run_inference(session_id, query)

    if session_id is None:
        session_path.write_text(inference_session_id)
    elif inference_session_id != session_id:
        sys.exit(
            f"Session ID mismatch between inference result and session file: "
            f"{inference_session_id} != {session_id}"
        )

    answer_path = thread_path / _get_answer_pathname(next_idx)
    answer_path.write_text(answer)


def _run_inference(session_id: str | None, query: str) -> tuple[str, str]:
    command = [
        "claude",
        # Make it stateless
        "--system-prompt",
        SYSTEM_PROMPT,
        "--print",
        # TODO: Understand which tool to activate & when
        "--tools",
        "",
        # To stream answer text
        "--include-partial-messages",
        "--output-format",
        "stream-json",
        "--verbose",
        query,
    ]

    if session_id is not None:
        command.extend(["--resume", session_id])

    process = subprocess.Popen(  # noqa: S603  (command is not user-provided)
        command,
        # --bare / CLAUDE_CODE_SIMPLE disables OAuth and routes billing to API
        # Still, as long as we set CWD to a bare directory, no CLAUDE.md will be
        # picked up
        cwd=EMPTY_CWD_PATH,
        stdout=subprocess.PIPE,
        text=True,
    )

    if process.stdout is None:
        sys.exit("Unexpected error: Claude stdout not captured")

    first_line = process.stdout.readline()
    first_event = json.loads(first_line)
    process_session_id = first_event["session_id"]

    # clear screen, helps keeping text stationary as it streams
    sys.stdout.write("\033[2J\033[H")
    answer_buf = io.StringIO()
    for line in process.stdout:
        event = json.loads(line)

        if event["type"] != "stream_event":
            continue
        if event["event"]["type"] != "content_block_delta":
            continue
        if event["event"]["delta"]["type"] != "text_delta":
            continue
        text = event["event"]["delta"]["text"]

        answer_buf.write(text)
        for char in text:
            sys.stdout.write(char)
            sys.stdout.flush()
            time.sleep(CHAR_DELAY)

    answer_buf.write("\n")
    sys.stdout.write("\n")

    process.wait()
    if process.returncode != 0:
        sys.exit(process.returncode)

    return process_session_id, answer_buf.getvalue()


def _get_next_idx(thread_path: Path) -> int:
    return len(list(thread_path.glob("??A.md")))


def _get_query_pathname(idx: int) -> str:
    return f"{idx:02d}A.md"


def _get_answer_pathname(idx: int) -> str:
    return f"{idx:02d}B.md"


if __name__ == "__main__":
    main()
