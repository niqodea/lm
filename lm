def _write_threads_summary(names: list[str], out: IO[str], threads_path: Path) -> None:
    for name in names:
        path = threads_path / name
        out.write(_format_thread_summary_line(path) + "\n")


def _format_thread_summary_line(path: Path) -> str:
    parts: list[str] = []

    name = path.name
    parts.append(f"{_compress_text(name, max_length=LS_NAME_LENGTH):<{LS_NAME_LENGTH}}")
    parts.append("   ")

    turns_count = _get_turns_count(path)
    parts.append(f"{turns_count:{TURN_IDX_ZEROPAD}d}t")
    parts.append("   ")

    last_turn_idx = turns_count - 1
    last_turn_path = path / f"{last_turn_idx:0{TURN_IDX_ZEROPAD}d}"

    last_prompt_path = last_turn_path / PROMPT_PATHNAME
    if not last_prompt_path.exists():
        parts.append(f"{'':<{LS_PROMPT_LENGTH}}")
    else:
        last_prompt = _compress_text(
            _flatten_text(last_prompt_path.read_text()),
            max_length=LS_PROMPT_LENGTH,
        )
        parts.append(f"{last_prompt:<{LS_PROMPT_LENGTH}}")

    parts.append("   ")

    last_response_path = last_turn_path / RESPONSE_PATHNAME
    if not last_response_path.exists():
        parts.append(f"{'':<{LS_RESPONSE_LENGTH}}")
    else:
        last_response = _compress_text(
            _flatten_text(last_response_path.read_text()),
            max_length=LS_RESPONSE_LENGTH,
        )
        parts.append(f"{last_response:<{LS_RESPONSE_LENGTH}}")

    return "".join(parts)


