def _add_thread_args(parser: argparse.ArgumentParser, *, required: bool) -> None:
    group = parser.add_mutually_exclusive_group(required=required)
    group.add_argument(
        "-t",
        "--thread",
        help="Thread name (maps to ~/.config/lm/threads/<name>)",
    )
    group.add_argument(
        "-l",
        "--last",
        action="store_true",
        help="Use the last active thread.",
    )
    group.add_argument(
        "-s",
        "--select",
        action="store_true",
        help="Pick a thread interactively.",
    )


def _has_thread_arg(args: argparse.Namespace) -> bool:
    return args.thread is not None or args.last is True or args.select is True


def _get_thread_arg(args: argparse.Namespace, threads_path: Path) -> str:
    if isinstance(args.thread, str):
        if not (threads_path / args.thread).exists():
            sys.exit("Thread does not exist.")
        return args.thread
    if args.last is True:
        names = _get_threads(threads_path)
        if not names:
            sys.exit("No threads found.")
        return names[0]
    if args.select is True:
        return _select_thread(threads_path)
    raise RuntimeError("Thread not in arguments.")


def _select_thread(threads_path: Path) -> str:
    names = _get_threads(threads_path)
    if not names:
        sys.exit("No threads found.")

    summary_to_name = {_format_thread_summary_line(threads_path / n): n for n in names}

    result = subprocess.run(
        ["fzf", "--no-sort"],  # noqa: S607  (we expect path variable to be safe)
        input="\n".join(summary_to_name),
        stdout=subprocess.PIPE,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        sys.exit("No thread selected.")

    return summary_to_name[result.stdout.rstrip("\n")]


def _get_threads(threads_path: Path) -> list[str]:
    paths = sorted(
        [p for p in threads_path.iterdir() if p.is_dir()],
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    return [p.name for p in paths]


def _edit_prompt(thread_path: Path, draft: str) -> str:
    editmsg_path = thread_path / EDITMSG_PATHNAME
    history = _build_history(thread_path)
    editor = os.getenv("EDITOR", "vim")

    prompt_is_last = editor in PROMPT_IS_LAST_EDITORS

    if prompt_is_last:
        command = [editor, "+", str(editmsg_path)]
        scissors_line_component = (
            "<!-- Everything above this scissors line will be ignored. -->\n"
            f"{SCISSORS_LINE}\n"
        )
    else:
        command = [editor, str(editmsg_path)]
        scissors_line_component = (
            f"{SCISSORS_LINE}\n"
            "<!-- Everything below this scissors line will be ignored. -->\n"
        )

    components: list[str] = []
    for turn_idx, (turn_prompt, turn_response) in enumerate(history):
        components.append(f"<!-- Prompt {turn_idx} -->\n\n{turn_prompt}")
        components.append(f"<!-- Answer {turn_idx} -->\n\n{turn_response}")

    if components:
        components.append(scissors_line_component)

    components.append(draft)

    if not prompt_is_last:
        components.reverse()

    editmsg_path.write_text("\n\n".join(components))

    with Path("/dev/tty").open() as tty:  # in case stdin is being piped
        subprocess.run(  # noqa: S603  (running the user editor expected to be safe)
            command,
            stdin=tty,
            stdout=sys.stdout,
            stderr=sys.stderr,
            check=True,
        )

    editmsg_fragments = editmsg_path.read_text().split(f"\n{SCISSORS_LINE}\n")
    editmsg_path.unlink()

    prompt = editmsg_fragments[-1] if prompt_is_last else editmsg_fragments[0]

    return prompt.strip()


def _execute_turn(
    *,
    model: str,
    session_path: Path,
    prompt: str,
    piped_stdin: str,
    response_path: Path,
    char_delay: float,
    claude_empty_cwd_path: Path,
) -> None:
    session_id: str | None = session_path.read_text() if session_path.exists() else None

    prompt_summary = _compress_text(
        _flatten_text(prompt), max_length=PROMPT_SUMMARY_MAX_LENGTH
    )

    sys.stdout.write(f"Prompt: {prompt_summary}\nWaiting for response...")
    sys.stdout.flush()

    inference_session_id, response = _run_inference(
        model=model,
        session_id=session_id,
        prompt=prompt,
        piped_stdin=piped_stdin,
        char_delay=char_delay,
        claude_empty_cwd_path=claude_empty_cwd_path,
    )

    if session_id is None:
        _write_read_only(session_path, inference_session_id)
    elif inference_session_id != session_id:
        sys.exit(
            f"Session ID mismatch between inference result and session file: "
            f"{inference_session_id} != {session_id}"
        )

    _write_read_only(
        response_path, response
    )  # seems like \n is always there at the end


def _run_inference(
    *,
    model: str,
    session_id: str | None,
    prompt: str,
    piped_stdin: str,
    char_delay: float,
    claude_empty_cwd_path: Path,
) -> tuple[str, str]:
    command = [
        "claude",
        prompt,
        "--model",
        model,
        # Make it stateless
        "--system-prompt",
        SYSTEM_PROMPT,
        "--print",
        "--tools",
        "",
        # To stream response text
        "--include-partial-messages",
        "--output-format",
        "stream-json",
        "--verbose",
    ]

    if session_id is not None:
        command.extend(["--resume", session_id])

    process = subprocess.Popen(  # noqa: S603  (command is not user-provided)
        command,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        text=True,
        # --bare / CLAUDE_CODE_SIMPLE disables OAuth and routes billing to API
        # Still, as long as we set CWD to a bare directory, no CLAUDE.md will be
        # picked up.
        cwd=claude_empty_cwd_path,
    )

    if process.stdin is None or process.stdout is None:
        sys.exit("Unexpected error: Claude standard streams not captured")

    process.stdin.write(piped_stdin)
    process.stdin.close()

    first_line = process.stdout.readline()
    first_event = json.loads(first_line)
    process_session_id = first_event["session_id"]

    # clear screen, helps keeping text stationary as it streams
    sys.stdout.write("\033[2J\033[H")
    buffer = io.StringIO()
    for line in process.stdout:
        event = json.loads(line)

        if event["type"] != "stream_event":
            continue
        if event["event"]["type"] != "content_block_delta":
            continue
        if event["event"]["delta"]["type"] != "text_delta":
            continue
        text = event["event"]["delta"]["text"]

        buffer.write(text)

        if char_delay == 0.0:
            sys.stdout.write(text)
            sys.stdout.flush()
        else:
            for char in text:
                sys.stdout.write(char)
                sys.stdout.flush()
                time.sleep(char_delay)

    buffer.write("\n")
    sys.stdout.write("\n")

    response = buffer.getvalue()

    process.wait()
    if process.returncode != 0:
        sys.exit(process.returncode)

    return process_session_id, response


def _get_turns_count(thread_path: Path) -> int:
    for idx in count():
        turn_path = thread_path / f"{idx:0{TURN_IDX_ZEROPAD}d}"
        if not turn_path.exists():
            return idx
    raise AssertionError("Unreachable")


def _get_preset(name: str, config_path: Path) -> str:
    presets_path = config_path / PRESETS_PATHNAME
    path = presets_path / f"{name}.md"
    if not path.exists():
        sys.exit(f"Preset not found: {path}")
    return path.read_text()


def _compress_text(value: str, max_length: int) -> str:
    if len(value) <= max_length:
        return value
    left = max_length // 2
    right = max_length - left - 3
    return f"{value[:left]}...{value[-right:]}"


def _flatten_text(value: str) -> str:
    return " ".join(value.split())


def _build_history(thread_path: Path) -> list[tuple[str, str]]:
    entries: list[tuple[str, str]] = []
    for idx in range(_get_turns_count(thread_path)):
        turn_path = thread_path / f"{idx:0{TURN_IDX_ZEROPAD}d}"
        prompt_path = turn_path / PROMPT_PATHNAME
        response_path = turn_path / RESPONSE_PATHNAME
        prompt = prompt_path.read_text()
        response = response_path.read_text()
        entries.append((prompt, response))
    return entries


def _get_char_delay_from_settings(config_path: Path) -> float:
    settings_path = config_path / SETTINGS_PATHNAME
    settings = tomllib.loads(settings_path.read_text())
    return float(settings.get(SETTINGS_CHAR_DELAY_KEY, "0"))


def _get_config_path(*, missing_ok: bool) -> Path:
    if (xdg_config_home := os.environ.get("XDG_CONFIG_HOME")) is not None:
        config_home_path = Path(xdg_config_home)
    else:
        config_home_path = Path.home() / ".config"

    path = config_home_path / "lm"

    if not missing_ok and not path.exists():
        sys.exit(f"Config directory not found: {path}\nRun `lm init` to initialize it.")

    return path


def _get_data_path(*, missing_ok: bool) -> Path:
    if (lm_data_dir := os.environ.get(LM_DATA_DIR_ENV)) is not None:
        path = Path(lm_data_dir)
    else:
        if (xdg_data_home := os.environ.get("XDG_DATA_HOME")) is not None:
            data_home_path = Path(xdg_data_home)
        else:
            data_home_path = Path.home() / ".local/share"
        path = data_home_path / "lm"

    if not missing_ok and not path.exists():
        sys.exit(f"Data directory not found: {path}\nRun `lm init` to initialize it.")

    return path


def _write_read_only(path: Path, content: str) -> None:
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o444)
    with os.fdopen(fd, "w") as f:
        f.write(content)


if __name__ == "__main__":
    main()
