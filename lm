#!/usr/bin/env python3
"""CLI tool for interacting with Claude from the terminal."""

import argparse
import datetime
import io
import json
import os
import subprocess
import sys
import time
from itertools import count
from pathlib import Path
from typing import IO

CONFIG_PATH = Path.home() / ".config" / "lm"
PRESETS_PATH = CONFIG_PATH / "presets"
EMPTY_CWD_PATH = CONFIG_PATH / ".empty-cwd"

THREADS_PATH = CONFIG_PATH / "threads"

TURN_IDX_ZEROPAD = 2
MODEL_PATHNAME = ".model"
SESSION_PATHNAME = ".session"
EDITMSG_PATHNAME = ".EDITMSG.md"
STAGED_PATHNAME = "STAGED"

PROMPT_PATHNAME = "prompt.md"
RESPONSE_PATHNAME = "response.md"
ATTACHMENTS_PATHNAME = "attachments"
STDIN_PATHNAME = "stdin"


SCISSORS_LINE = "<!-- ------------------------ >8 ------------------------ -->"

# TODO: Understand whether you can change this within a session
SYSTEM_PROMPT = """\
You are a helpful assistant. Answer the question concisely.
"""

PROMPT_SUMMARY_MAX_LENGTH = 100

# TODO: should we avoid hardcoding this? works fine for current latencies, but might be
# annoying if streaming becomes faster in the future. Perhaps configurable, perhaps
# automatically adapt?
CHAR_DELAY = 1 / 1000

# TODO: Provide something to initialize config directory once
# TODO: Implement forking with symlinks to share common history between threads
# Seems like we will need to fork at each turn to edit previous messages
# TODO: Inspect claude command flags for further improvements
# TODO: Address annoying UX of text moving upwards as the answer is being streamed
# TODO: Implement top-to-bottom message strategy, but only with recognized editors that
# can place the cursor at the bottom
# TODO: Differentate prompt (text part) vs query (the whole)
# TODO: files to resume conversation are stored locally!
# We could leverage this to tap into some advanced use cases and efficiency improvements
# as well as avoiding having two different states that might contradict each other
# (if we manage to generate claude-compatible state on the fly, for example)

LS_NAME_LENGTH = 15
LS_PROMPT_LENGTH = 30
LS_RESPONSE_LENGTH = 50

DEFAULT_MODEL = "claude-sonnet-4-6"


def main() -> None:
    """Entry point for the lm CLI."""
    parser = argparse.ArgumentParser(prog="lm")
    # TODO: Should we differentiate thread creation vs continuation?

    subparsers = parser.add_subparsers(dest="command", required=True)

    run_parser = subparsers.add_parser(
        "run",
        help="Stage a query and run inference in one command.",
    )
    run_parser.set_defaults(func=_cmd_run)
    run_parser.add_argument(
        "-t",
        "--thread",
        help="Thread name (maps to ~/.config/lm/threads/<name>)",
    )
    run_parser.add_argument(
        "--preset",
        help="Preset name (maps to ~/.config/lm/presets/<name>.md)",
    )

    new_parser = subparsers.add_parser(
        "new",
        help="Start a new thread.",
    )
    new_parser.set_defaults(func=_cmd_new)
    new_parser.add_argument(
        "name",
        help="Thread name (maps to ~/.config/lm/threads/<name>)",
    )
    new_parser.add_argument(
        "--model",
        help="Model to use for this thread.",
        default=DEFAULT_MODEL,
    )

    stage_parser = subparsers.add_parser(
        "stage",
        help="Stage a query without running inference.",
    )
    stage_parser.set_defaults(func=_cmd_stage)
    stage_parser.add_argument(
        "-t",
        "--thread",
        help="thread name (maps to ~/.config/lm/threads/<name>)",
        required=True,
    )
    stage_parser.add_argument(
        "--preset",
        help="prompt name (maps to ~/.config/lm/presets/<name>.md)",
    )

    commit_parser = subparsers.add_parser(
        "commit",
        help="Run inference on the staging area.",
    )
    commit_parser.set_defaults(func=_cmd_commit)
    commit_parser.add_argument(
        "-t",
        "--thread",
        help="Thread name (maps to ~/.config/lm/threads/<name>)",
        required=True,
    )

    clear_parser = subparsers.add_parser(
        "clear",
        help="Clear the staging area without running inference.",
    )
    clear_parser.set_defaults(func=_cmd_clear)
    clear_parser.add_argument(
        "--thread",
        help="Thread name (maps to ~/.config/lm/threads/<name>)",
        required=True,
    )

    ls_parser = subparsers.add_parser("ls", help="List threads.")
    ls_parser.set_defaults(func=_cmd_ls)

    args = parser.parse_args()
    args.func(args)


def _cmd_run(args: argparse.Namespace) -> None:
    thread_name: str | None = args.thread
    preset_name: str | None = args.preset

    if thread_name is not None:
        thread_path = THREADS_PATH / thread_name
    else:
        thread_timestamp = (
            datetime.datetime.now().astimezone().strftime("%Y%m%d-%H%M%S")
        )
        sys.stdout.write(f"Creating new thread: {thread_timestamp}\n")
        thread_path = THREADS_PATH / thread_timestamp
        thread_path.mkdir()
        model_path = thread_path / MODEL_PATHNAME
        model_path.write_text(DEFAULT_MODEL)

    if not thread_path.exists():
        sys.exit("Thread does not exist.")

    if (thread_path / STAGED_PATHNAME).exists():
        sys.exit(
            "Staging area already exists, cannot run. "
            "Please commit or clear the staging area first."
        )

    draft = _get_preset(preset_name) if preset_name is not None else ""

    prompt = _edit_prompt(thread_path, draft)
    if not prompt:
        sys.exit("Prompt is empty, exiting.")

    # TODO: Maybe instantiate this only after the response is received?
    turn_idx = _get_turns_count(thread_path)
    turn_path = thread_path / f"{turn_idx:0{TURN_IDX_ZEROPAD}d}"
    turn_path.mkdir()

    prompt_path = turn_path / PROMPT_PATHNAME
    prompt_path.write_text(prompt)

    if sys.stdin.isatty():
        piped_stdin = ""
    else:
        piped_stdin = sys.stdin.read()
        stdin_path = turn_path / STDIN_PATHNAME
        stdin_path.write_text(piped_stdin)

    model_path = thread_path / MODEL_PATHNAME
    model = model_path.read_text()

    _execute_turn(
        model=model,
        session_path=thread_path / SESSION_PATHNAME,
        prompt=prompt,
        piped_stdin=piped_stdin,
        response_path=turn_path / RESPONSE_PATHNAME,
    )


def _cmd_new(args: argparse.Namespace) -> None:
    name: str = args.name
    model: str = args.model

    path = THREADS_PATH / name
    if path.exists():
        sys.exit("Thread already exists.")
    path.mkdir()

    # We tie the thread to a single model for simplicity
    model_path = path / MODEL_PATHNAME
    model_path.write_text(model)


def _cmd_stage(args: argparse.Namespace) -> None:
    thread_name: str = args.thread
    preset_name: str | None = args.preset

    thread_path = THREADS_PATH / thread_name
    if not thread_path.exists():
        sys.exit("Thread does not exist.")

    staged_path = thread_path / STAGED_PATHNAME
    staged_path.mkdir(exist_ok=True)

    staged_prompt_path = staged_path / PROMPT_PATHNAME

    match staged_prompt_path.exists(), preset_name:
        case False, None:
            draft = ""
        case False, str():
            draft = _get_preset(preset_name)
        case True, None:
            draft = staged_prompt_path.read_text()
        case True, str():
            sys.exit("Staged prompt already exists, cannot apply preset.")

    prompt = _edit_prompt(thread_path, draft)

    staged_prompt_path.write_text(prompt)


def _cmd_commit(args: argparse.Namespace) -> None:
    thread_name: str = args.thread

    thread_path = THREADS_PATH / thread_name
    if not thread_path.exists():
        sys.exit("Thread does not exist.")

    staged_path = thread_path / STAGED_PATHNAME
    if not thread_path.exists():
        sys.exit("No staging area found.")

    staged_prompt_path = staged_path / PROMPT_PATHNAME
    if not staged_prompt_path.exists():
        sys.exit("No staged prompt found.")

    prompt = staged_prompt_path.read_text()
    if not prompt:
        sys.exit("Prompt is empty, exiting.")

    turn_idx = _get_turns_count(thread_path)
    turn_path = thread_path / f"{turn_idx:0{TURN_IDX_ZEROPAD}d}"
    staged_path.rename(turn_path)

    model_path = thread_path / MODEL_PATHNAME
    model = model_path.read_text()

    _execute_turn(
        model=model,
        session_path=thread_path / SESSION_PATHNAME,
        prompt=prompt,
        piped_stdin="",
        response_path=turn_path / RESPONSE_PATHNAME,
    )


def _cmd_clear(args: argparse.Namespace) -> None:
    thread_name: str = args.thread
    thread_path = THREADS_PATH / thread_name

    if not thread_path.exists():
        sys.exit("Thread does not exist.")

    staged_path = thread_path / STAGED_PATHNAME

    if not staged_path.exists():
        sys.exit("No staging area found.")

    staged_prompt_path = staged_path / PROMPT_PATHNAME
    staged_prompt_path.unlink(missing_ok=True)

    staged_path.rmdir()


def _cmd_ls(_: argparse.Namespace) -> None:
    paths = sorted(
        (p for p in THREADS_PATH.iterdir() if p.is_dir()),
        # NOTE: Not a super robust way to sort by last activity, but simple and works
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    names = [p.name for p in paths]

    if not sys.stdout.isatty():
        _write_threads_summary(names, sys.stdout)
        return

    pager = os.getenv("PAGER", "less")
    env = os.environ.copy()
    env.setdefault("LESS", "-FRX")
    with subprocess.Popen(  # noqa: S603  (running the user pager expected to be safe)
        pager,
        stdin=subprocess.PIPE,
        text=True,
    ) as pager_proc:
        if pager_proc.stdin is None:
            sys.exit("Unexpected error: Pager standard input not captured")
        _write_threads_summary(names, pager_proc.stdin)


def _write_threads_summary(names: list[str], out: IO[str]) -> None:
    for name in names:
        out.write(
            f"{_compress_text(name, max_length=LS_NAME_LENGTH):<{LS_NAME_LENGTH}}"
        )

        out.write("   ")

        path = THREADS_PATH / name
        turns_count = _get_turns_count(path)
        out.write(f"{turns_count:{TURN_IDX_ZEROPAD}d}t")

        out.write("   ")

        last_turn_idx = turns_count - 1
        last_turn_path = path / f"{last_turn_idx:0{TURN_IDX_ZEROPAD}d}"

        last_prompt_path = last_turn_path / PROMPT_PATHNAME
        if not last_prompt_path.exists():
            out.write(f"{'':<{LS_PROMPT_LENGTH}}")
        else:
            last_prompt = _compress_text(
                _flatten_text(last_prompt_path.read_text()),
                max_length=LS_PROMPT_LENGTH,
            )
            out.write(f"{last_prompt:<{LS_PROMPT_LENGTH}}")

        out.write("   ")

        last_response_path = last_turn_path / RESPONSE_PATHNAME
        if not last_response_path.exists():
            out.write(f"{'':<{LS_RESPONSE_LENGTH}}")
        else:
            last_response = _compress_text(
                _flatten_text(last_response_path.read_text()),
                max_length=LS_RESPONSE_LENGTH,
            )
            out.write(f"{last_response:<{LS_RESPONSE_LENGTH}}")

        out.write("\n")


# ---


def _edit_prompt(thread_path: Path, draft: str) -> str:
    editmsg_path = thread_path / EDITMSG_PATHNAME
    history = _build_history(thread_path)

    with editmsg_path.open("w") as f:
        f.write(draft)
        if history:
            f.write(f"\n\n{SCISSORS_LINE}\n\n")
            for idx, (prompt, response) in reversed(list(enumerate(history))):
                f.write(f"<!-- Response {idx} -->\n\n{response}\n\n")
                f.write(f"<!-- Prompt {idx} -->\n\n{prompt}\n\n")

    editor = os.getenv("EDITOR", "vim")
    with Path("/dev/tty").open() as tty:
        subprocess.run(  # noqa: S603  (running the user editor expected to be safe)
            [editor, str(editmsg_path)],
            stdin=tty,
            stdout=sys.stdout,
            stderr=sys.stderr,
            check=True,
        )

    prompt = editmsg_path.read_text().split(f"\n{SCISSORS_LINE}\n")[0].strip()
    editmsg_path.unlink()
    return prompt


def _execute_turn(
    *,
    model: str,
    session_path: Path,
    prompt: str,
    piped_stdin: str,
    response_path: Path,
) -> None:
    session_id: str | None = session_path.read_text() if session_path.exists() else None

    prompt_summary = _compress_text(
        _flatten_text(prompt), max_length=PROMPT_SUMMARY_MAX_LENGTH
    )

    sys.stdout.write(f"Prompt: {prompt_summary}\nWaiting for lm response...")
    sys.stdout.flush()

    inference_session_id, response = _run_inference(
        model=model,
        session_id=session_id,
        prompt=prompt,
        piped_stdin=piped_stdin,
    )

    if session_id is None:
        session_path.write_text(inference_session_id)
    elif inference_session_id != session_id:
        sys.exit(
            f"Session ID mismatch between inference result and session file: "
            f"{inference_session_id} != {session_id}"
        )

    response_path.write_text(response)


def _run_inference(
    *, model: str, session_id: str | None, prompt: str, piped_stdin: str
) -> tuple[str, str]:
    command = [
        "claude",
        prompt,
        "--model",
        model,
        # Make it stateless
        "--system-prompt",
        SYSTEM_PROMPT,
        "--print",
        # TODO: Understand which tool to activate & when
        "--tools",
        "",
        # To stream response text
        "--include-partial-messages",
        "--output-format",
        "stream-json",
        "--verbose",
    ]

    if session_id is not None:
        command.extend(["--resume", session_id])

    process = subprocess.Popen(  # noqa: S603  (command is not user-provided)
        command,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        text=True,
        # --bare / CLAUDE_CODE_SIMPLE disables OAuth and routes billing to API
        # Still, as long as we set CWD to a bare directory, no CLAUDE.md will be
        # picked up
        cwd=EMPTY_CWD_PATH,
    )

    if process.stdin is None or process.stdout is None:
        sys.exit("Unexpected error: Claude standard streams not captured")

    # TODO: Understand difference of stdin vs @ read directives
    # If not that different, we could think of unifying stdin as just another attachment
    process.stdin.write(piped_stdin)
    process.stdin.close()

    first_line = process.stdout.readline()
    first_event = json.loads(first_line)
    process_session_id = first_event["session_id"]

    # clear screen, helps keeping text stationary as it streams
    sys.stdout.write("\033[2J\033[H")
    buffer = io.StringIO()
    for line in process.stdout:
        event = json.loads(line)

        if event["type"] != "stream_event":
            continue
        if event["event"]["type"] != "content_block_delta":
            continue
        if event["event"]["delta"]["type"] != "text_delta":
            continue
        text = event["event"]["delta"]["text"]

        buffer.write(text)
        for char in text:
            sys.stdout.write(char)
            sys.stdout.flush()
            time.sleep(CHAR_DELAY)

    buffer.write("\n")
    sys.stdout.write("\n")

    response = buffer.getvalue()

    process.wait()
    if process.returncode != 0:
        sys.exit(process.returncode)

    return process_session_id, response


def _get_turns_count(thread_path: Path) -> int:
    for idx in count():
        turn_path = thread_path / f"{idx:0{TURN_IDX_ZEROPAD}d}"
        if not turn_path.exists():
            return idx
    raise AssertionError("Unreachable")


def _get_preset(name: str) -> str:
    path = PRESETS_PATH / f"{name}.md"
    if not path.exists():
        sys.exit(f"Preset not found: {path}")
    return path.read_text()


def _compress_text(value: str, max_length: int) -> str:
    if len(value) <= max_length:
        return value
    left = max_length // 2
    right = max_length - left - 3
    return f"{value[:left]}...{value[-right:]}"


def _flatten_text(value: str) -> str:
    return " ".join(value.split())


def _build_history(thread_path: Path) -> list[tuple[str, str]]:
    entries: list[tuple[str, str]] = []
    for idx in range(_get_turns_count(thread_path)):
        turn_path = thread_path / f"{idx:0{TURN_IDX_ZEROPAD}d}"
        prompt_path = turn_path / PROMPT_PATHNAME
        response_path = turn_path / RESPONSE_PATHNAME
        prompt = prompt_path.read_text()
        response = response_path.read_text()
        entries.append((prompt, response))
    return entries


if __name__ == "__main__":
    main()
